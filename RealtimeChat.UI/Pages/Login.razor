@page "/login"
@using System.Net.Http.Json
@using RealtimeChat.UI.Auth
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>@(isRegistering ? "Register" : "Login")</PageTitle>

<div class="login-container">
    <h3 class="login-header">
        @(isRegistering ? "Create an Account" : "Login")
    </h3>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-alert">
            @errorMessage
        </div>
    }

    @if (isRegistering)
    {
        <div class="form-group">
            <label class="form-label">Display Name:</label>
            <input @bind="displayNameInput" placeholder="e.g. Anton Petrov" class="form-input" />
        </div>
        <div class="form-group">
            <label class="form-label">Unique Tag:</label>
            <input @bind="shortIdInput" placeholder="e.g. cigseller123" class="form-input" />
        </div>
    }

    <div class="form-group">
        <label class="form-label">Email:</label>
        <input @bind="emailInput" placeholder="user@chat.com" class="form-input" />
    </div>
    <div class="form-group-large">
        <label class="form-label">Password:</label>
        <input @bind="passwordInput" type="password" class="form-input" />
    </div>

    @if (isRegistering)
    {
        <button @onclick="SubmitRegister" class="btn-register">Register</button>
        <div class="link-container">
            <a href="javascript:void(0)" @onclick="ToggleMode" class="toggle-link">Already have an account? Log in</a>
        </div>
    }
    else
    {
        <button @onclick="SubmitLogin" class="btn-login">Login</button>
        <div class="link-container">
            <a href="javascript:void(0)" @onclick="ToggleMode" class="toggle-link">Need an account? Register</a>
        </div>
    }
</div>

@code {
    private bool isRegistering = false;

    private string displayNameInput = "";
    private string shortIdInput = "";
    private string emailInput = "";
    private string passwordInput = "";
    private string? errorMessage;

    private void ToggleMode()
    {
        isRegistering = !isRegistering;
        errorMessage = null;
    }

    private async Task SubmitRegister()
    {
        errorMessage = null;
        
        var payload = new { 
            email = emailInput, 
            password = passwordInput, 
            displayName = displayNameInput, 
            shortId = shortIdInput 
        };
        
        try 
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", payload);
            
            if (response.IsSuccessStatusCode)
            {
                await SubmitLogin(); 
            }
            else
            {
                var errorResult = await response.Content.ReadFromJsonAsync<HttpValidationProblemDetails>();
                if (errorResult?.Errors != null && errorResult.Errors.Any())
                {
                    errorMessage = string.Join(" | ", errorResult.Errors.SelectMany(e => e.Value));
                }
                else
                {
                    errorMessage = "Registration failed. Please check your inputs.";
                }
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Could not connect to the server. Is the API running?";
        }
    }

    private async Task SubmitLogin()
    {
        errorMessage = null;
        try 
        {
            var response = await Http.PostAsJsonAsync("/login", new { email = emailInput, password = passwordInput });
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result?.AccessToken != null)
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.AccessToken);
                    ((JwtAuthStateProvider)AuthStateProvider).NotifyUserLoggedIn(emailInput);
                    NavManager.NavigateTo("/chatrooms");
                }
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Could not connect to the server. Is the API running?";
        }
    }

    private class LoginResult { public string? AccessToken { get; set; } }
    
    private class HttpValidationProblemDetails 
    { 
        public Dictionary<string, string[]> Errors { get; set; } = new(); 
    }
}